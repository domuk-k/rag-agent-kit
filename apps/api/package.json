{
  "name": "@repo/api",
  "version": "0.1.0",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./app": "./src/app.ts"
  },
  "scripts": {
    "dev": "bun run --env-file=../../.env --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "start": "bun run dist/index.js"
  },
  "dependencies": {
    "@elysiajs/bearer": "^1.4.2",
    "@elysiajs/cors": "^1.2.0",
    "@repo/agents": "workspace:*",
    "@repo/db": "workspace:*",
    "@repo/shared": "workspace:*",
    "@repo/vector": "workspace:*",
    "elysia": "^1.2.0"
  },
  "devDependencies": {
    "@types/bun": "latest"
  }
}
