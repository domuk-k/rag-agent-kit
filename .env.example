# OpenRouter API
OPENROUTER_API_KEY=sk-or-v1-your-api-key-here
OPENROUTER_MODEL=google/gemini-2.5-flash-preview-05-20

# OpenAI Embedding API
OPENAI_API_KEY=sk-your-openai-api-key-here
# Or use separate key for embeddings only:
# OPENAI_EMBEDDING_API_KEY=sk-your-embedding-api-key-here

# Embedding Configuration (defaults shown)
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMENSION=512

# SQLite (macOS: brew install sqlite 필요)
# SQLITE_LIB_PATH=/opt/homebrew/opt/sqlite/lib/libsqlite3.dylib

# Server
PORT=8080

# Client
VITE_API_URL=http://localhost:8080

# Admin Auth (FAQ CRUD 보호용)
ADMIN_TOKEN=your-admin-secret-token

# Langfuse (Optional - Prompt Management & Observability)
LANGFUSE_PUBLIC_KEY=pk-lf-xxx
LANGFUSE_SECRET_KEY=sk-lf-xxx
# LANGFUSE_HOST=https://cloud.langfuse.com  # Default, or self-hosted URL
