{
  "family": "ax-tap-cs",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "2048",
  "executionRoleArn": "arn:aws:iam::590183835934:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::590183835934:role/AX-TAP-API-Role",
  "containerDefinitions": [
    {
      "name": "api",
      "image": "590183835934.dkr.ecr.ap-northeast-2.amazonaws.com/ax-tap-cs:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8080,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "PORT", "value": "8080" },
        { "name": "MONGODB_DB_NAME", "value": "tap-cs-staging" }
      ],
      "secrets": [
        {
          "name": "MONGODB_URI",
          "valueFrom": "arn:aws:secretsmanager:ap-northeast-2:590183835934:secret:TAP/CS/DEV-mrOYzJ:MONGODB_URI::"
        },
        {
          "name": "ADMIN_TOKEN",
          "valueFrom": "arn:aws:secretsmanager:ap-northeast-2:590183835934:secret:TAP/CS/DEV-mrOYzJ:ADMIN_TOKEN::"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/ax-tap-cs",
          "awslogs-region": "ap-northeast-2",
          "awslogs-stream-prefix": "api"
        }
      },
      "healthCheck": {
        "command": ["CMD-SHELL", "bun -e \"fetch('http://localhost:8080/health').then(r=>r.ok?process.exit(0):process.exit(1)).catch(()=>process.exit(1))\""],
        "interval": 30,
        "timeout": 10,
        "retries": 5,
        "startPeriod": 120
      }
    }
  ]
}
